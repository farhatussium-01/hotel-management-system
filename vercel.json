{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/js/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "frontend/pages/$1"
    },
    {
      "src": "/(admin|staff|guest|login|register)\\.html",
      "dest": "frontend/pages/$1.html"
    },
    {
      "src": "/(.*\\.html)",
      "dest": "frontend/pages/$1"
    },
    {
      "src": "/",
      "dest": "frontend/pages/login.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/pages/login.html"
    }
  ]
}